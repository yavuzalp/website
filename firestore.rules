rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /arenaProblems/{problemId} {
      allow read: if true;
      allow write: if false;
    }

    match /arenaRooms/{roomCode} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == 'waiting';

      allow update: if request.auth != null && (
        (resource.data.hostUid == request.auth.uid
          && resource.data.status == 'waiting'
          && request.resource.data.status == 'active'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','problemIds','startedAt','endsAt']))
        ||
        (resource.data.status == 'active'
          && request.resource.data.status == 'finished'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','finishedAt'])
          && exists(/databases/$(database)/documents/arenaRooms/$(roomCode)/players/$(request.auth.uid)))
      );

      allow delete: if false;

      match /players/{uid} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == uid;
        allow update: if request.auth != null && request.auth.uid == uid;
        allow delete: if false;

        match /private/{submissionId} {
          allow read: if request.auth != null && (
            request.auth.uid == uid ||
            get(/databases/$(database)/documents/arenaRooms/$(roomCode)).data.status == 'finished'
          );
          allow write: if request.auth != null && request.auth.uid == uid;
        }
      }
    }
  }
}
