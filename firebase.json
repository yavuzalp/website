{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "algoarena",
      "public": "algoarena",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/room/**", "destination": "/index.html" }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
        }
      ]
    }
  ]
}
